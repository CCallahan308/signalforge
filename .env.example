# Environment variables for SignalForge
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://signalforge_user:SignalForge2024!@localhost:5432/signalforge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=signalforge_user
POSTGRES_PASSWORD=SignalForge2024!
POSTGRES_DB=signalforge

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Security
SECRET_KEY=change-this-to-a-random-string-in-production
API_KEY_HEADER=X-API-Key
API_KEYS=your-api-key-here

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=signalforge_churn

# Kaggle (for data download)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Model settings
MODEL_RETRAIN_CRON=0 2 * * 1
DRIFT_DETECTION_THRESHOLD=0.15
MIN_SAMPLES_FOR_RETRAIN=1000

# Feature store
FEATURE_STORE_TYPE=redis
REDIS_HOST=localhost
REDIS_PORT=6379
