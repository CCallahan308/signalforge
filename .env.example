# SignalForge Environment Configuration
# Copy to .env and fill in values

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=signalforge_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=signalforge

# Admin user for setup
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=CHANGE_ME

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=signalforge_churn

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Security
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
API_KEY_HEADER=X-API-Key
API_KEYS=your-api-key-here

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # or text

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Airflow
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql://signalforge_user:CHANGE_ME@localhost:5432/signalforge

# Features
FEATURE_STORE_TYPE=redis  # or memory
REDIS_HOST=localhost
REDIS_PORT=6379

# Models
MODEL_RETRAIN_CRON=0 2 * * 1  # Weekly on Monday 2 AM
DRIFT_DETECTION_THRESHOLD=0.15
MIN_SAMPLES_FOR_RETRAIN=1000

# Data
DATA_SEED=42
SYNTHETIC_ACCOUNTS=10000

# Business
# Intervention budget for ROI simulation
INTERVENTION_BUDGET_USD=10000
AVERAGE_INTERVENTION_COST_USD=150
